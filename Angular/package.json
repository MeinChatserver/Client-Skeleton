  "license": "MIT",
  "description": "OpenSource Angular & TypeScript based Client for Mein-ChatServer.",
  "keywords": [ "chat", "client", "angular", "typescript", "mein-chatserver"],
  "homepage": "https://mein-chatserver.de/",
  "bugs": {
    "url": "https://github.com/MeinChatserver/Client-Skeleton/issues",
    "email": "support@mein-chatserver.de"
  },
  "author": {
    "name": "Bizarrus",
    "email": "support@mein-chatserver.de",
    "url": "https://mein-chatserver.de/"
  },
  "scripts": {
    "ng": "ng",
    "start": "ng serve Angular",
    "build": "ng build",
    "watch": "ng build --watch --configuration development",
    "test": "ng test"
  },
  "prettier": {
    "printWidth": 100,
    "singleQuote": true,
    "overrides": [
      {
        "files": "*.html",
        "options": {
          "parser": "angular"
        }
      }
    ]
  },
  "private": true,
  "packageManager": "npm@11.14.1",
  "dependencies": {
    "@angular/common": "^21.2.12",
    "@angular/compiler": "^21.2.12",
    "@angular/core": "^21.2.12",
    "@angular/forms": "^21.2.12",
    "@angular/platform-browser": "^21.2.12",
    "@angular/router": "^21.2.12",
    "rxjs": "~7.8.2",
    "tslib": "^2.8.1"
  },
  "devDependencies": {
    "@angular-devkit/build-angular": "^21.2.10",
    "@angular/build": "^21.2.10",
    "@angular/cli": "^21.2.10",
    "@angular/compiler-cli": "^21.2.12",
    "jsdom": "^29.1.1",
    "typescript": "~5.9.2",
    "vitest": "^4.1.5"
  }
